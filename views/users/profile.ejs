<%layout("/layouts/boilerplate")%>
<div class="row mt-5 mb-5">
    
    <!-- Left Column: Quick ID Badge -->
    <div class="col-md-4 mb-4">
        <div class="card shadow-sm border-0 rounded-4 text-center p-4">
            <!-- Placeholder Avatar (We can add real image uploads later) -->
            <div class="mb-3">
                <i class="fa-solid fa-circle-user text-secondary" style="font-size: 6rem;"></i>
            </div>
            
            <h3 class="fw-bold mb-1"><%= currUser.firstName || currUser.username %> <%= currUser.lastName || '' %></h3>
            <p class="text-muted mb-3">@<%= currUser.username %></p>
            
            <div class="mb-3">
                <% if(currUser.role === 'host') { %>
                    <span class="badge rounded-pill text-bg-dark px-3 py-2">Host Account</span>
                <% } else { %>
                    <span class="badge rounded-pill px-3 py-2" style="background-color: #fc424d;">Guest Account</span>
                <% } %>
            </div>
            
            <hr>
            
            <div class="text-start mt-3">
                <p class="mb-2"><i class="fa-solid fa-envelope me-2 text-muted"></i> <%= currUser.email %></p>
                <% if(currUser.contactNumber) { %>
                    <p class="mb-0"><i class="fa-solid fa-phone me-2 text-muted"></i> <%= currUser.contactNumber %></p>
                <% } else { %>
                    <p class="mb-0 text-muted fst-italic"><i class="fa-solid fa-phone me-2 text-muted"></i> No phone added</p>
                <% } %>
            </div>
        </div>
    </div>

    <!-- Right Column: About & Actions -->
    <div class="col-md-8">
        <div class="card shadow-sm border-0 rounded-4 p-4 h-100">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h4 class="fw-bold m-0">About Me</h4>
                <!-- The Edit Button (Logic to be implemented in next step) -->
                <a href="/profile/edit" class="btn btn-outline-dark rounded-pill px-4">Edit Profile</a>
            </div>
            
            <div class="mb-4">
                <% if(currUser.bio) { %>
                    <p class="fs-5" style="line-height: 1.6;"><%= currUser.bio %></p>
                <% } else { %>
                    <p class="text-muted fst-italic fs-5">This user hasn't written a bio yet.</p>
                <% } %>
            </div>
            
            <!-- Future Feature Placeholder: We will show the host's listings here later -->
           <% if(currUser.role === 'host') { %>
                <hr class="mb-4">
                <h5 class="fw-bold mb-3">My Properties</h5>
                
                <% if(userListings && userListings.length > 0) { %>
                    <div class="row row-cols-1 row-cols-md-2 g-4">
                        <% for(let listing of userListings) { %>
                            <div class="col">
                                <a href="/listings/<%= listing._id %>" class="text-decoration-none">
                                    <div class="card h-100 shadow-sm border-0 listing-card">
                                        <img src="<%= listing.image.url %>" class="card-img-top rounded-4" alt="Property Image" style="height: 12rem; object-fit: cover;">
                                        <div class="card-body p-2 mt-2">
                                            <h6 class="card-title fw-bold text-dark mb-1"><%= listing.title %></h6>
                                            <p class="card-text text-muted small mb-0"><%= listing.location %>, <%= listing.country %></p>
                                            <p class="card-text text-dark fw-bold mt-1">&#8377;<%= listing.price.toLocaleString("en-IN") %></p>
                                        </div>
                                    </div>
                                </a>
                            </div>
                        <% } %>
                    </div>
                <% } else { %>
                    <div class="alert alert-light text-center border rounded-4 p-4 mt-3">
                        <div class="mb-3">
                            <i class="fa-solid fa-house-chimney-window text-muted" style="font-size: 3rem;"></i>
                        </div>
                        <p class="text-muted mb-3 fs-5">You haven't listed any properties yet.</p>
                        <a href="/listings/new" class="btn btn-dark rounded-pill px-4">Airbnb your home</a>
                    </div>
                <% } %>
            <% } %>
        </div>
    </div>

</div>