<%layout("/layouts/boilerplate")%>
<div class="row mt-5 mb-5">
    <div class="col-12">
        <h2 class="fw-bold mb-4">My Trips</h2>
        
        <% if(trips && trips.length > 0) { %>
            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                <% for(let trip of trips) { %>
                    <div class="col">
                        <div class="card h-100 shadow-sm border-0 listing-card">
                            <img src="<%= trip.listing.image.url %>" class="card-img-top rounded-4" alt="Property Image" style="height: 15rem; object-fit: cover;">
                            
                            <div class="card-body p-3 mt-2">
                                <h5 class="card-title fw-bold text-dark mb-1"><%= trip.listing.title %></h5>
                                <p class="card-text text-muted small mb-2"><%= trip.listing.location %>, <%= trip.listing.country %></p>
                                
                                <hr class="my-2">
                                
                                <p class="card-text mb-1">
                                    <i class="fa-regular fa-calendar me-2 text-danger"></i>
                                    <strong>Check-in:</strong> <%= trip.checkIn.toLocaleDateString() %>
                                </p>
                                <p class="card-text mb-2">
                                    <i class="fa-regular fa-calendar-check me-2 text-danger"></i>
                                    <strong>Check-out:</strong> <%= trip.checkOut.toLocaleDateString() %>
                                </p>
                                
                                <div class="d-flex justify-content-between align-items-center mt-3 bg-light p-2 rounded-3">
                                    <span class="text-muted small">Total Cost</span>
                                    <span class="fw-bold fs-5 text-dark">&#8377;<%= trip.totalPrice.toLocaleString("en-IN") %></span>
                                </div>
                            </div>
                        </div>
                    </div>
                <% } %>
            </div>
        <% } else { %>
            <div class="alert alert-light text-center border rounded-4 p-5 mt-3">
                <i class="fa-solid fa-plane-departure text-muted mb-3" style="font-size: 3rem;"></i>
                <h4 class="text-dark fw-bold">No trips booked... yet!</h4>
                <p class="text-muted fs-5 mb-4">Time to dust off your bags and start planning your next adventure.</p>
                <a href="/listings" class="btn btn-outline-dark rounded-pill px-5 py-2 fw-bold">Start Searching</a>
            </div>
        <% } %>
    </div>
</div>