<%layout("/layouts/boilerplate")%>
<body>
   <style>
    #filters{
      margin-top: 1rem;
        display: flex;
      flex-wrap: wrap;
    }
    .filter{
       text-align: center;
       margin-right: 2rem;
       margin-top: 2rem;
       opacity: 0.7;
    }
    .filter-link {
        text-decoration: none;
        color: black;
    }
    .filter:hover{
      opacity: 1;
      cursor:pointer;
    }
    .filter p{
      font-size: 0.8rem;
    }
   </style>
     <div id="filters">
      <a href="/listings?category=Trending" class="filter-link">
          <div class="filter">
            <div><i class="fa-solid fa-fire"></i></div>
            <p>Trending</p>
          </div>
      </a>
      
      <a href="/listings?category=Rooms" class="filter-link">
          <div class="filter">
            <div><i class="fa-solid fa-bed"></i></div>
            <p>Rooms</p>
          </div>
      </a>
      
      <a href="/listings?category=Iconic Cities" class="filter-link">
          <div class="filter">
            <div><i class="fa-solid fa-mountain-city"></i></div>
            <p>Iconic Cities</p>
          </div>
      </a>
      
      <a href="/listings?category=Mountains" class="filter-link">
          <div class="filter">
            <div><i class="fa-solid fa-mountain"></i></div>
            <p>Mountains</p>
          </div>
      </a>
      
      <a href="/listings?category=Castles" class="filter-link">
          <div class="filter">
            <div><i class="fa-solid fa-fort-awesome"></i></div>
            <p>Castles</p>
          </div>
      </a>
      
      <a href="/listings?category=Amazing Pools" class="filter-link">
          <div class="filter">
            <div><i class="fa-solid fa-person-swimming"></i></div>
            <p>Amazing Pools</p>
          </div>
      </a>
      
      <a href="/listings?category=Camping" class="filter-link">
          <div class="filter">
            <div><i class="fa-solid fa-campground"></i></div>
            <p>Camping</p>
          </div>
      </a>
      
      <a href="/listings?category=Farms" class="filter-link">
          <div class="filter">
            <div><i class="fa-solid fa-cow"></i></div>
            <p>Farms</p>
          </div>
      </a>
      
      <a href="/listings?category=Arctic" class="filter-link">
          <div class="filter">
            <div><i class="fa-solid fa-snowflake"></i></div>
            <p>Arctic</p>
          </div>
      </a>
     </div>
    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
        <% if(allListings.length === 0) { %>
            <div class="col-12 text-center mt-5 mb-5 p-5 bg-light rounded-4 border">
                <i class="fa-solid fa-magnifying-glass mb-3 text-muted" style="font-size: 3rem;"></i>
                <h3 class="text-dark fw-bold">No exact matches found</h3>
                <p class="text-muted fs-5">Try changing your search terms or clearing your filters.</p>
                <a href="/listings" class="btn btn-dark rounded-pill mt-3 px-4 py-2">Clear Search</a>
            </div>
        <% } else { %>
         <% for(let listing of allListings ){%>
                <a href="/listings/<%= listing._id %>" class="listing-link">
                    <div class="card col listing-card shadow-sm border-0 h-100 position-relative">
                        <img src="<%= listing.image.url%>" class="card-img-top rounded-4" alt="listing image" style="height:20rem; object-fit: cover;"/>
                        
                        <% const isLiked = currUser && currUser.wishlist && currUser.wishlist.some(id => id.toString() === listing._id.toString()) %>
                        
                      <button onclick="toggleHeart(event, '<%= listing._id %>')" class="btn position-absolute top-0 end-0 m-3 p-2 bg-white rounded-circle shadow" style="width: 40px; height: 40px; z-index: 10;">
    <i id="heart-<%= listing._id %>" class="<%= (currUser && currUser.wishlist && currUser.wishlist.some(id => id.toString() === listing._id.toString())) ? 'fa-solid text-danger' : 'fa-regular text-dark' %> fa-heart fs-5"></i>
</button>

                        <div class="card-img-overlay"></div>
                        <div class="card-body p-2 mt-2">
                            <p class="card-text">
                                <span class="fw-bold text-dark"><%= listing.title %></span><br>
                                <span class="text-muted small"><%= listing.category %> • <%= listing.location %></span><br>
                                <span class="text-dark fw-bold">&#8377;<%=listing.price.toLocaleString("en-IN")%></span> / night
                            </p>
                        </div>
                    </div>
                </a>
            <% } %>
        <% } %>
     </div>
<script>
    async function toggleHeart(event, listingId) {
        event.preventDefault(); 
        
        try {
            const response = await fetch(`/wishlist/${listingId}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            });
            
            const data = await response.json();
            
            // 🎯 KEY FOCUS 3: Handling the Server-Side Redirect Signal
            if (data.redirect) {
                window.location.href = data.redirect;
                return;
            }
            
            const heartIcon = document.getElementById(`heart-${listingId}`);
            if (data.liked) {
                heartIcon.classList.remove('fa-regular', 'text-dark');
                heartIcon.classList.add('fa-solid', 'text-danger');
            } else {
                heartIcon.classList.remove('fa-solid', 'text-danger');
                heartIcon.classList.add('fa-regular', 'text-dark');
            }
        } catch (err) {
            console.error("Error toggling wishlist:", err);
        }
    }
</script>
<script>
    // 🎯 KEY FOCUS 7: Redirect logged-out users to login page
    function requireLogin(event) {
        if(event) event.preventDefault(); // Stop the link from opening the listing
        window.location.href = "/login";
    }
</script>
</body>