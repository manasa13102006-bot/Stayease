<% layout("/layouts/boilerplate") %>
    <div class="row-mt-3">
        <div class="col-8 offset-3">
    <h3><%=listing.title%></h3>
 </div>
    <div class="card col-6 offset-3 show-card listing-card">
     <img src="<%= listing.image.url%>" class="card-img-top show-img" alt="listing img"/>
    <div class="card-body">
    <p class="card-text">
        <i>Owned By<%= listing.owner.username %></i>  </p>
          <p class="card-text"> <%= listing.description%> </p>
        <p class="card-text"> &#8377;<%= listing.price.toLocaleString("en-IN") %> </p>
          <p class="card-text"> <%= listing.location %></p>
           <p class="card-text"><%= listing.country %> </p>
           <div class="mt-4">
    <h4>Location</h4>
    <div
        id="map"
        style="height:400px; width:100%; border-radius:10px;">
    </div>
</div>
    </div>
     </div>
     <!-- BUTTON -->
    <% if(currUser && listing.owner._id.equals(currUser.id)) {  %> 
    <div class="btns"><a href="/listings/<%= listing._id%>/edit" class="btn btn-dark col-1 offset-3 edit-btn">EDIT</a>
    <form method="POST" action="/listings/<%=listing._id %>?_method=DELETE">
        <button class="btn btn-dark offset-5">DELETE</button>
    </form>
    </div>
    <% } %>
    <div class="col-8 offset-2 mb-4">
        <% if(currUser && !currUser._id.equals(listing.owner._id)) { %>
            <hr class="mb-4">
            <h4 class="fw-bold mb-3">Book this place</h4>
            <div class="card shadow-sm border-0 rounded-4 p-4">
                <form action="/listings/<%= listing._id %>/bookings" method="POST" class="needs-validation" novalidate>
                    <div class="row">
                        <div class="mb-3 col-md-6">
                            <label for="checkIn" class="form-label fw-bold">Check-in Date</label>
                            <input type="text" id="checkIn" name="booking[checkIn]" class="form-control rounded-3" required>
                            <div class="invalid-feedback">Please select a valid check-in date.</div>
                        </div>
                        
                        <div class="mb-3 col-md-6">
                            <label for="checkOut" class="form-label fw-bold">Check-out Date</label>
                            <input type="text" id="checkOut" name="booking[checkOut]" class="form-control rounded-3" required>
                            <div class="invalid-feedback">Please select a valid check-out date.</div>
                        </div>
                    </div>
                    
                    <button class="btn btn-danger w-100 rounded-pill mt-3 py-2 fw-bold" style="background-color: #fc424d;">
                        Reserve
                    </button>
                </form>
            </div>
            
        <% } else if (!currUser) { %>
            <hr class="mb-4">
            <div class="alert alert-light border rounded-4 text-center p-4">
                <h5 class="fw-bold">Want to book this place?</h5>
                <p class="text-muted">You must be logged in to reserve dates.</p>
                <a href="/login" class="btn btn-outline-dark rounded-pill px-4">Log in to Book</a>
            </div>
        <% } %>
    </div>
    <!-- review -->
    <div class="col-8 offset-3 mb-3"><hr/>
     <% if(currUser) { %>
        <h4>Leave the review</h4>
        <form action="/listings/<%= listing._id%>/reviews" method="POST" novalidate class="needs-validation">
    <!-- <div class="mb-3 mt-3" >
        <label for="rating" class="form-label">rating</label>
        <input type="range" min="1" max="5" id="rating" name="review[rating]" class="form-range"/>
    </div> -->
    <div class="mb-3 mt-3" >
    <label for="rating" class="form-label">rating</label>
  <fieldset class="starability-slot">
  <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1 " checked aria-label="No rating." />
  <input type="radio" id="first-rate1" name="review[rating]" value="1" />
  <label for="first-rate1" title="Terrible">1 star</label>
  <input type="radio" id="first-rate2" name="review[rating]" value="2" />
  <label for="first-rate2" title="Not good">2 stars</label>
  <input type="radio" id="first-rate3" name="review[rating]" value="3" />
  <label for="first-rate3" title="Average">3 stars</label>
  <input type="radio" id="first-rate4" name="review[rating]" value="4" />
  <label for="first-rate4" title="Very good">4 stars</label>
  <input type="radio" id="first-rate5" name="review[rating]" value="5" />
  <label for="first-rate5" title="Amazing">5 stars</label>
  </fieldset>
  </div>
        <div class="mb-3 mt-3" >
        <label for="comment" class="form-label">comments</label>
        <textarea name="review[comment]" id="comment" cols="30" rows="3"class="form-control" required></textarea>
        <div class="invalid-feedback">please write comment</div>
     </div>
   <button class="btn btn-outline-dark">submit</button>
</form>
    <% } %>
<p>All reviews</p>
<div class="row">
    <%for( review of listing.reviews){ %>
        <div class="card col-5 ms-3 mb-3">
       <h5 class="card-title">@<%= review.author.username %></h5>
       <p class="starability-result card-text" data-rating=<%=review.rating%>></p>
       <p class="card-text"><%=review.comment%></p>
        <form class="mb-3"action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" method="POST">
        <button class="btn btn-sm btn btn-dark">Delete</button>
        </form>
        </div>
       
        <% }  %>
</div>
      </div>
     </div>

 <script>
    const MAPTILER_API_KEY = "<%= MAPTILER_API_KEY %>";

    const LISTING = {
        title: "<%= listing.title %>",
        geometry: {
            lat: <%= listing.geometry.lat %>,
            lng: <%= listing.geometry.lng %>
        }
    };
</script>

<script src="/js/display_map.js"></script>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>

<script>
        const existingBookings = <%- JSON.stringify(existingBookings || []) %>;
        
        const disabledDateRanges = existingBookings.map(booking => {
            return {
                from: booking.checkIn.split('T')[0],
                to: booking.checkOut.split('T')[0]
            };
        });

        // Initialize Check-In Calendar
        const checkInPicker = flatpickr("#checkIn", {
            minDate: "today", 
            disable: disabledDateRanges,
            dateFormat: "Y-m-d",
            onChange: function(selectedDates, dateStr, instance) {
                // 🎯 KEY FOCUS 4: Allow checkout on the exact same day
                if (selectedDates.length > 0) {
                    let minCheckout = new Date(selectedDates[0]);
                    // We removed the +1 day logic here!
                    checkOutPicker.set("minDate", minCheckout);
                }
            }
        });

        // Initialize Check-Out Calendar
        const checkOutPicker = flatpickr("#checkOut", {
            minDate: "today", // 🎯 KEY FOCUS 5: Changed from tomorrow to today
            disable: disabledDateRanges,
            dateFormat: "Y-m-d",
        });
    </script>